{
  "name": "tc-02",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev -p 3000",
    "build": "next build",
    "start": "node .next/standalone/server.js",
    "lint": "eslint . --ext .ts,.tsx,.js,.jsx",
    "check": "node scripts/check-build.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "docs": "cd docs && yarn start --port 3030",
    "docs:build": "cd docs && yarn build",
    "docker:build": "docker build -t bytebank-frontend .",
    "docker:run": "docker run -p 3000:3000 bytebank-frontend",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down",
    "docker:logs": "docker-compose logs -f",
    "docker:rebuild": "docker-compose down && docker-compose up -d --build",
    "docker:setup": "node scripts/docker-setup.js",
    "mf:setup": "node scripts/setup-microfrontends.js",
    "mf:dev": "docker-compose -f docker-compose.microfrontends.yml up -d",
    "mf:down": "docker-compose -f docker-compose.microfrontends.yml down",
    "mf:logs": "docker-compose -f docker-compose.microfrontends.yml logs -f",
    "mf:rebuild": "docker-compose -f docker-compose.microfrontends.yml down && docker-compose -f docker-compose.microfrontends.yml up -d --build",
    "mf:shell": "cd apps/shell && yarn dev",
    "mf:dashboard": "cd apps/dashboard && yarn dev",
    "mf:transactions": "cd apps/transactions && yarn dev",
    "mf:analytics": "cd apps/analytics && yarn dev"
  },
  "dependencies": {
    "@ai-sdk/google": "^3.0.82",
    "@ai-sdk/openai": "^3.0.71",
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@hookform/resolvers": "^5.2.2",
    "@mui/icons-material": "^7.3.9",
    "@mui/material": "^7.3.9",
    "ai": "^6.0.206",
    "chart.js": "^4.5.1",
    "groq-sdk": "^1.2.1",
    "html2canvas": "^1.4.1",
    "jspdf": "^4.2.1",
    "next": "16.1.6",
    "pdf-parse": "^2.4.5",
    "react": "19.2.3",
    "react-chartjs-2": "^5.3.1",
    "react-dom": "19.2.3",
    "react-hook-form": "^7.71.2",
    "xlsx": "^0.18.5",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "jest": "^30.3.0",
    "jest-environment-jsdom": "^30.3.0",
    "sass": "^1.98.0",
    "typescript": "^5"
  }
}
